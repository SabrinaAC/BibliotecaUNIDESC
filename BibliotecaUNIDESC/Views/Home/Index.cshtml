@model BibliotecaUNIDESC.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">

    <div class="mb-4">
        <h2 class="fw-bold">📚 Dashboard - Biblioteca UNIDESC</h2>
        <p class="text-muted">
            Bem-vinda, Sabrina! Gerencie sua biblioteca de forma simples e organizada.
        </p>
    </div>

    <div class="row g-4">

        <div class="col-md-3">
            <div class="card shadow border-0 text-center">
                <div class="card-body">
                    <i class="bi bi-book-fill fs-1 text-primary"></i>
                    <h5 class="mt-3">Livros</h5>
                    <h2>@Model.TotalLivros</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 text-center">
                <div class="card-body">
                    <i class="bi bi-box-seam fs-1 text-success"></i>
                    <h5 class="mt-3">Exemplares</h5>
                    <h2>@Model.LivrosDisponiveis</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 text-center">
                <div class="card-body">
                    <i class="bi bi-people-fill fs-1 text-warning"></i>
                    <h5 class="mt-3">Usuários</h5>
                    <h2>@Model.TotalUsuarios</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 text-center">
                <div class="card-body">
                    <i class="bi bi-arrow-left-right fs-1 text-danger"></i>
                    <h5 class="mt-3">Empréstimos</h5>
                    <h2>@Model.TotalEmprestimos</h2>
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow border-0 mt-5">

        <div class="card-header bg-white">

            <h5 class="mb-0">
                📖 Últimos livros cadastrados
            </h5>

        </div>

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead class="table-light">

                    <tr>

                        <th>Título</th>
                        <th>Autor</th>
                        <th>Categoria</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.UltimosLivros.Any())
                    {
                        @foreach (var livro in Model.UltimosLivros)
                        {
                            <tr>

                                <td>@livro.Titulo</td>
                                <td>@livro.Autor</td>
                                <td>@livro.Categoria</td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="3" class="text-center text-muted">

                                Nenhum livro cadastrado.

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>